# ── Meta / Facebook App ──────────────────────────────────────────────
# จาก Meta Developer Console > App > Settings > Basic
META_APP_ID=1234567890123456
META_APP_SECRET=your_app_secret_here

# Graph API version ที่จะเรียก (ต้องเป็น vXX.X)
META_GRAPH_VERSION=v19.0

# ต้องตรงกับ "Valid OAuth Redirect URIs" ใน Meta App > Facebook Login > Settings
META_REDIRECT_URI=http://localhost:4000/auth/facebook/callback

# Scope ที่ขอจาก user (ใช้เมื่อยังไม่ตั้ง config_id ด้านล่าง)
META_SCOPES=public_profile,ads_read,business_management

# Facebook Login for Business: config_id จาก Business Settings > Configurations
# ใส่ค่านี้เพื่อสลับไปใช้ FLB (config_id แทน scope, ได้ System User token เสถียร)
META_LOGIN_CONFIG_ID=

# ── Database ─────────────────────────────────────────────────────────
# SQLite (dev). Postgres: เปลี่ยน provider ใน prisma/schema.prisma เป็น postgresql
# แล้วตั้ง DATABASE_URL=postgresql://user:pass@host:5432/dbname
DATABASE_URL="file:./dev.db"

# ── Server ───────────────────────────────────────────────────────────
PORT=4000

# Origin ของ React frontend (ใช้กับ CORS และ redirect กลับหลัง login)
FRONTEND_ORIGIN=http://localhost:5173

# ความลับสำหรับ sign cookie (สุ่มยาว ๆ เช่น `openssl rand -hex 32`)
COOKIE_SECRET=change_me_to_a_long_random_string

# production | development — ควบคุมว่า cookie จะตั้ง Secure flag หรือไม่
NODE_ENV=development

# ── Access gate ──────────────────────────────────────────────────────
# รหัสที่ผู้ใช้ต้องกรอกในหน้า /gate ก่อนเข้าใช้งานเว็บหลัก (ตั้งเป็นค่าลับของคุณเอง)
ACCESS_CODE=change_me
